# Environment variables for Bug Triage Env
# Copy this file to .env and fill in your credentials
# NEVER commit .env with real keys — it is in .gitignore

# GitHub API (only needed for data pipeline)
GITHUB_TOKEN=

# LLM Inference — choose one provider:

# Option A: Ollama (local, free, no rate limits)
API_BASE_URL=http://localhost:11434/v1
MODEL_NAME=llama3.1:8b
OPENAI_API_KEY=ollama

# Option B: Groq (free tier, rate limited)
# API_BASE_URL=https://api.groq.com/openai/v1
# MODEL_NAME=llama-3.1-8b-instant
# OPENAI_API_KEY=

# Option C: OpenAI (pay-as-you-go)
# API_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o-mini
# OPENAI_API_KEY=

# Parallel inference threads (default: 4)
NUM_WORKERS=4

# HuggingFace (for deployment)
HF_TOKEN=
